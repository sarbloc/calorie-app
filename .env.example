# Supabase Configuration
# Copy this file to .env and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Function URL (for Telegram auth)
# Format: https://your-project.supabase.co/functions/v1
VITE_SUPABASE_EDGE_FUNCTION_URL=https://your-project.supabase.co/functions/v1

# OpenClaw secrets are stored as Supabase Edge Function secrets (not client-side)
# Set them via: supabase secrets set OPENCLAW_HOOKS_URL=... OPENCLAW_HOOKS_TOKEN=...
