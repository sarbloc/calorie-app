# Supabase Configuration
# Copy this file to .env and fill in your values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Function URL (for Telegram auth)
# Format: https://your-project.supabase.co/functions/v1
VITE_SUPABASE_EDGE_FUNCTION_URL=https://your-project.supabase.co/functions/v1

# OpenClaw Hooks (AI calorie estimation)
VITE_OPENCLAW_HOOKS_URL=https://your-tailscale-host/hooks
VITE_OPENCLAW_HOOKS_TOKEN=your-openclaw-hooks-token
